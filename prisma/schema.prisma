// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Photo metadata - stores like and view counts
model Photo {
  id        String @id
  likes     Int    @default(0)
  views     Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  photoLikes  PhotoLike[]
  photoViews  PhotoView[]

  @@index([id])
}

// Track likes by IP address
model PhotoLike {
  id        Int     @id @default(autoincrement())
  photoId   String
  ipAddress String  // Hashed IP for privacy
  createdAt DateTime @default(now())

  // Relations
  photo     Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([photoId, ipAddress])
  @@index([photoId])
  @@index([ipAddress])
}

// Track views by IP address
model PhotoView {
  id        Int     @id @default(autoincrement())
  photoId   String
  ipAddress String  // Hashed IP for privacy
  createdAt DateTime @default(now())

  // Relations
  photo     Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@unique([photoId, ipAddress])
  @@index([photoId])
  @@index([ipAddress])
}
